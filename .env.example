# ============================================================
# TADS Store — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores
# NUNCA commite o arquivo .env no GitHub
# ============================================================

# Supabase — obtenha em: https://supabase.com → Settings → API
VITE_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Mercado Pago — chave PÚBLICA (pode ficar no frontend)
# Obtenha em: https://www.mercadopago.com.br/developers/panel
# Use TEST-... em desenvolvimento; APP_USR-... só em produção.
VITE_MP_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Mercado Pago — Access Token (SEGREDO do servidor; NUNCA usar prefixo VITE_).
# Lido pela função serverless api/create-preference.js via process.env.
# Local: defina aqui no .env (lido pelo `vercel dev`).
# Produção: cadastre em Vercel → Project → Settings → Environment Variables.
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000

# DummyJSON API (não precisa alterar)
VITE_API_BASE_URL=https://dummyjson.com
